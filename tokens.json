      "background-hover":{ "value": "{global.colors.action.cta-hover.value}",  "type": "color" },
      "text":            { "value": "{global.colors.neutral.white.value}",      "type": "color" },
      "paddingX":        { "value": "{global.spacing.10}",                      "type": "spacing" },
      "paddingY":        { "value": "20px",                                     "type": "spacing" },
      "borderRadius":    { "value": "{global.borderRadius.md}",                 "type": "borderRadius" },
      "fontSize":        { "value": "{global.typography.fontSize.md}",          "type": "fontSizes" },
      "fontWeight":      { "value": "{global.typography.fontWeight.bold}",      "type": "fontWeights" },
      "shadow":          { "value": "{global.shadows.cta}",                     "type": "boxShadow" }
    },
    "section-card": {
      "background":   { "value": "{global.colors.neutral.white.value}",  "type": "color" },
      "border":       { "value": "rgba(201,169,122,0.20)",                "type": "color" },
      "borderRadius": { "value": "{global.borderRadius.xl}",              "type": "borderRadius" },
      "shadow":       { "value": "{global.shadows.card-sm}",              "type": "boxShadow" },
      "padding":      { "value": "{global.spacing.8}",                    "type": "spacing" }
    },
    "fv-hero": {
      "bg-gradient": {
        "value": "linear-gradient(155deg, {global.colors.hero.bg-dark-1.value} 0%, {global.colors.hero.bg-dark-2.value} 38%, {global.colors.hero.bg-dark-3.value} 100%)",
        "type": "other",
        "description": "FVヒーロー背景グラデーション（CSSそのまま使用可）"
      },
      "title-color":    { "value": "{global.colors.hero.text-primary.value}", "type": "color" },
      "title-em-from":  { "value": "{global.colors.hero.gradient-start.value}", "type": "color" },
      "title-em-to":    { "value": "{global.colors.hero.gradient-end.value}", "type": "color" },
      "sub-color":      { "value": "{global.colors.hero.text-sub.value}", "type": "color" },
      "eyebrow-color":  { "value": "{global.colors.brand.gold-light.value}", "type": "color" },
      "ring-color":     { "value": "{global.colors.hero.ring.value}", "type": "color" },
